# Reactable Agent — chat panel

Native `AgentWindow` loads this page at `/agent`. Nexus orchestrates tools;
Gemma runs in `reactable-tools` (Rust MLX).

client :agent do
  <style>
    * { box-sizing: border-box; }
    html, body {
      margin: 0; height: 100%; overflow: hidden;
      font: 13px/1.5 ui-sans-serif, system-ui, -apple-system, sans-serif;
      background: #09090b; color: #ececee;
      -webkit-font-smoothing: antialiased;
    }
    .app {
      display: grid;
      grid-template-rows: auto 1fr auto;
      height: 100vh;
      background: #141414;
    }

    /* ── Header ── */
    header {
      padding: 10px 16px 8px;
      background: transparent;
    }
    .header-row {
      display: flex; align-items: center; gap: 8px; min-width: 0;
    }
    .header-row h1 {
      font-size: 14px; font-weight: 650; margin: 0;
      letter-spacing: -.02em; color: #fafafa;
    }
    .badge {
      flex-shrink: 0;
      font: 10px/1 ui-monospace, SFMono-Regular, Menlo, monospace;
      color: #a5b4fc;
      background: rgba(99,102,241,.14);
      border: 1px solid rgba(129,140,248,.28);
      padding: 3px 8px; border-radius: 999px;
    }
    .header-meta {
      margin-top: 6px;
      font: 11px/1.4 ui-monospace, SFMono-Regular, Menlo, monospace;
      color: #71717a;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .header-meta.ok { color: #6ee7b7; }
    .header-meta.warn { color: #fbbf24; }

    /* ── Log ── */
    #log {
      overflow: auto;
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      scroll-behavior: smooth;
    }
    .msg {
      max-width: min(92%, 520px);
      padding: 10px 13px;
      border-radius: 14px;
      line-height: 1.55;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .msg.user {
      align-self: flex-end;
      background: linear-gradient(135deg, #4338ca, #3730a3);
      color: #fff;
      border-bottom-right-radius: 4px;
      box-shadow: 0 4px 14px rgba(67,56,202,.25);
    }
    .msg.assistant {
      align-self: flex-start;
      background: rgba(24,24,27,.95);
      border: 1px solid rgba(255,255,255,.08);
      border-bottom-left-radius: 4px;
    }
    /* Rendered markdown inside assistant messages */
    .msg.assistant p { margin: 0 0 8px; }
    .msg.assistant p:last-child { margin-bottom: 0; }
    .msg.assistant h1, .msg.assistant h2, .msg.assistant h3, .msg.assistant h4 {
      margin: 10px 0 6px; font-weight: 650; letter-spacing: -.01em; color: #fafafa;
    }
    .msg.assistant h1 { font-size: 16px; } .msg.assistant h2 { font-size: 15px; }
    .msg.assistant h3, .msg.assistant h4 { font-size: 13px; }
    .msg.assistant ul { margin: 4px 0 8px; padding-left: 20px; }
    .msg.assistant li { margin: 2px 0; }
    .msg.assistant strong { font-weight: 650; color: #fafafa; }
    .msg.assistant a { color: #a5b4fc; }
    .msg.assistant code {
      font: 11.5px/1.4 ui-monospace, SFMono-Regular, Menlo, monospace;
      background: rgba(255,255,255,.08); padding: 1px 5px; border-radius: 5px;
    }
    .msg.assistant pre {
      background: rgba(0,0,0,.35); border: 1px solid rgba(255,255,255,.07);
      border-radius: 10px; padding: 10px 12px; overflow-x: auto; margin: 6px 0;
    }
    .msg.assistant pre code { background: none; padding: 0; color: #e4e4e7; }
    .msg.typing {
      color: #a1a1aa;
      font-style: italic;
      animation: pulse 1.2s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100% { opacity: .45; } 50% { opacity: .9; } }
    .msg.system {
      align-self: center;
      max-width: 100%;
      text-align: center;
      font-size: 11px;
      color: #71717a;
      background: transparent;
      padding: 8px 12px;
    }
    .msg.error {
      align-self: stretch;
      font-size: 12px;
      color: #fca5a5;
      background: rgba(248,113,113,.08);
      border: 1px solid rgba(248,113,113,.2);
    }
    .banner {
      align-self: stretch;
      display: flex; gap: 10px; align-items: flex-start;
      padding: 10px 12px;
      border-radius: 12px;
      background: rgba(248,113,113,.08);
      border: 1px solid rgba(248,113,113,.22);
      color: #fca5a5;
      font-size: 12px;
      line-height: 1.45;
    }
    .banner code {
      font: 11px/1.4 ui-monospace, SFMono-Regular, Menlo, monospace;
      display: block;
      margin-top: 6px;
      padding: 6px 8px;
      border-radius: 8px;
      background: rgba(0,0,0,.35);
      color: #fecaca;
      word-break: break-all;
    }
    .tools {
      font: 10px ui-monospace, monospace;
      color: #a1a1aa;
      margin-top: 8px;
      opacity: .9;
    }

    /* ── Composer ── */
    .composer-wrap {
      padding: 12px 2px 4px;
      background: transparent;
    }
    .composer {
      display: flex;
      flex-direction: column;
      gap: 0;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.1);
      background: rgba(20,20,24,.95);
      box-shadow: 0 8px 32px rgba(0,0,0,.35);
      overflow: hidden;
      transition: border-color .15s, box-shadow .15s;
    }
    .composer:focus-within {
      border-color: rgba(99,102,241,.55);
      box-shadow: 0 8px 32px rgba(0,0,0,.35), 0 0 0 1px rgba(99,102,241,.25);
    }
    textarea {
      width: 100%;
      min-height: 52px;
      max-height: 160px;
      padding: 12px 14px 8px;
      border: 0;
      resize: none;
      background: transparent;
      color: #f4f4f5;
      font: inherit;
      line-height: 1.5;
    }
    textarea::placeholder { color: #52525b; }
    textarea:focus { outline: none; }
    .composer-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      padding: 6px 8px 8px;
      border-top: 1px solid rgba(255,255,255,.05);
    }
    .composer-hint {
      font-size: 10px;
      color: #52525b;
      padding-left: 6px;
      user-select: none;
    }
    .composer-actions {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      height: 30px;
      padding: 0 12px;
      border: 0;
      border-radius: 8px;
      font: 600 12px/1 ui-sans-serif, system-ui, sans-serif;
      cursor: pointer;
      transition: background .12s, opacity .12s;
    }
    .btn:disabled { opacity: .4; cursor: not-allowed; }
    .btn-ghost {
      background: rgba(255,255,255,.06);
      color: #a1a1aa;
    }
    .btn-ghost:hover:not(:disabled) { background: rgba(255,255,255,.1); color: #e4e4e7; }
    .btn-primary {
      background: #6366f1;
      color: #fff;
      min-width: 64px;
    }
    .btn-primary:hover:not(:disabled) { background: #5558e3; }
    .btn svg {
      width: 14px; height: 14px;
      stroke: currentColor; fill: none;
      stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round;
    }

    /* ── Model picker ── */
    .badge-btn {
      margin-left: auto; flex-shrink: 0;
      font: 11px/1 ui-sans-serif, system-ui, sans-serif; color: #a1a1aa;
      background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
      padding: 5px 10px; border-radius: 999px; cursor: pointer;
    }
    .badge-btn:hover { background: rgba(255,255,255,.1); color: #e4e4e7; }
    #models { overflow: auto; padding: 16px; display: none; flex-direction: column; gap: 12px; }
    #models.show { display: flex; }
    .models-intro { font-size: 13px; color: #a1a1aa; }
    .models-intro b { color: #fafafa; }
    .hw { font: 11px ui-monospace, monospace; color: #71717a; }
    .tier {
      border: 1px solid rgba(255,255,255,.1); border-radius: 14px;
      padding: 14px 16px; background: rgba(24,24,27,.7);
      display: flex; flex-direction: column; gap: 6px;
    }
    .tier.rec { border-color: rgba(129,140,248,.5); box-shadow: 0 0 0 1px rgba(99,102,241,.2); }
    .tier-top { display: flex; align-items: center; gap: 8px; }
    .tier-name { font-size: 15px; font-weight: 650; color: #fafafa; text-transform: capitalize; }
    .tier-label { font-size: 12px; color: #a5b4fc; }
    .tier-pill {
      font: 10px/1 ui-monospace, monospace; padding: 3px 7px; border-radius: 999px;
      border: 1px solid rgba(129,140,248,.3); color: #a5b4fc; background: rgba(99,102,241,.12);
    }
    .tier-pill.warn { color: #fbbf24; border-color: rgba(251,191,36,.3); background: rgba(251,191,36,.1); }
    .tier-pill.ok { color: #6ee7b7; border-color: rgba(52,211,153,.3); background: rgba(16,185,129,.12); }
    .tier-blurb { font-size: 12px; color: #a1a1aa; }
    .tier-meta { font: 11px ui-monospace, monospace; color: #71717a; }
    .tier-actions { display: flex; gap: 8px; margin-top: 4px; }
    .tier-actions .btn { height: 30px; padding: 0 14px; }
    /* ——— monochrome retheme + menu/tools/tail (overrides above rules) ——— */
    html, body { background: #141414; color: #e7e7e7; }
    .badge { background: #161616; border: 1px solid #2c2c2c; color: #d4d4d4; }
    .btn-primary { background: #ededed; color: #0a0a0a; }
    .btn-primary:hover { background: #fff; }
    .composer { background: #101010; border-color: #262626; }
    .composer:focus-within { border-color: #4a4a4a; box-shadow: none; }
    .msg.user .content { background: #1c1c1c; border: 1px solid #2a2a2a; }
    .msg.assistant .content { background: transparent; }
    a { color: #d4d4d4; }
    .menu-btn { width: 30px; height: 30px; margin-left: auto; border: 1px solid #2c2c2c; border-radius: 8px; background: #141414; color: #b3b3b3; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; }
    .menu-btn:hover { color: #fff; border-color: #3d3d3d; }
    .menu-btn svg { width: 15px; height: 15px; stroke: currentColor; fill: none; stroke-width: 1.8; stroke-linecap: round; }
    #menu { position: absolute; top: 52px; right: 12px; z-index: 40; width: 300px; max-height: 70vh; overflow-y: auto; background: #0f0f0f; border: 1px solid #2a2a2a; border-radius: 12px; box-shadow: 0 18px 50px rgba(0,0,0,.6); padding: 6px; }
    .menu-title { font: 600 10px/1 ui-monospace, monospace; letter-spacing: .12em; text-transform: uppercase; color: #6f6f6f; padding: 10px 10px 6px; }
    .menu-section + .menu-section { border-top: 1px solid #1f1f1f; margin-top: 4px; }
    .menu-row { display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 8px; color: #d4d4d4; text-decoration: none; font-size: 12.5px; }
    .menu-row:hover { background: #1a1a1a; }
    .menu-row svg { width: 15px; height: 15px; stroke: currentColor; fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; opacity: .8; }
    .menu-row .chev { margin-left: auto; color: #565656; }
    .tool-row { display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 8px; font-size: 12.5px; color: #d4d4d4; }
    .tool-row:hover { background: #161616; }
    .tool-row svg { width: 15px; height: 15px; stroke: currentColor; fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; opacity: .8; }
    .tool-row .name { flex: 1; }
    .tool-more { border: 0; background: none; color: #6f6f6f; cursor: pointer; font-size: 15px; padding: 0 2px; }
    .tool-more:hover { color: #fff; }
    .tool-toggle { position: relative; width: 30px; height: 17px; border-radius: 999px; background: #2a2a2a; border: 0; cursor: pointer; transition: background .15s; }
    .tool-toggle::after { content: ''; position: absolute; top: 2px; left: 2px; width: 13px; height: 13px; border-radius: 50%; background: #8a8a8a; transition: transform .15s, background .15s; }
    .tool-toggle.on { background: #e7e7e7; }
    .tool-toggle.on::after { transform: translateX(13px); background: #0a0a0a; }
    .tool-prompt { display: none; padding: 4px 10px 10px 35px; }
    .tool-prompt.open { display: block; }
    .tool-prompt textarea { width: 100%; min-height: 44px; background: #141414; border: 1px solid #2a2a2a; border-radius: 8px; color: #ddd; font: 12px/1.4 inherit; padding: 7px 9px; resize: vertical; }
    .send-plane { width: 34px; height: 30px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: 8px; }
    .send-plane svg { width: 15px; height: 15px; stroke: currentColor; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
    /* activity tail — thin shimmer strip under the log while thinking */
    #tail { height: 3px; margin: 0 14px; border-radius: 3px; opacity: 0; background: linear-gradient(90deg, #1c1c1c, #efefef, #1c1c1c); background-size: 200% 100%; transition: opacity .25s ease; }
    #tail.on { opacity: 1; animation: tailFlow 1.4s linear infinite; }
    @keyframes tailFlow { to { background-position: 200% 0; } }
  </style>
  <div class="app">
    <header>
      <div class="header-row">
        <span class="badge" id="engine">MiniMax-M3</span>
        <span class="header-meta" id="status" hidden></span>
        <button type="button" class="menu-btn" id="menu-btn" title="Menu">
          <svg viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </header>

    <div id="menu" hidden>
      <div class="menu-section">
        <div class="menu-title">Account</div>
        <a class="menu-row link" href="https://platform.minimax.io" target="_blank">
          <svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
          <span>Top up credits</span><span class="chev">›</span>
        </a>
        <a class="menu-row link" href="#" id="connect-youtube">
          <svg viewBox="0 0 24 24"><path d="m10 9 5 3-5 3z"/><rect x="2" y="4" width="20" height="16" rx="4"/></svg>
          <span>Connect YouTube</span><span class="chev">›</span>
        </a>
        <a class="menu-row link" href="https://www.pexels.com/api/" target="_blank">
          <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-5-5L5 21"/></svg>
          <span>Connect stock (Pexels / Unsplash)</span><span class="chev">›</span>
        </a>
      </div>
      <div class="menu-section">
        <div class="menu-title">Tools</div>
        <div id="tool-list"></div>
      </div>
    </div>

    <div id="log"></div>
    <div id="models" hidden></div>

    <div id="tail"></div>
    <div class="composer-wrap">
      <div class="composer">
        <textarea id="input" rows="2" placeholder="Plan a deck, run the CLI, or describe a video…"></textarea>
        <div class="composer-bar">
          <span class="composer-hint">↵ send · ⇧↵ newline</span>
          <div class="composer-actions">
            <button type="button" class="btn btn-primary send-plane" id="send" title="Send">
              <svg viewBox="0 0 24 24"><path d="M22 2 11 13"/><path d="M22 2 15 22l-4-9-9-4z"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
  (function () {
    const log = document.getElementById('log');
    const input = document.getElementById('input');
    const sendBtn = document.getElementById('send');
    const statusEl = document.getElementById('status');
    const engineEl = document.getElementById('engine');
    const params = new URLSearchParams(location.search);
    const deck = params.get('deck') || 'demo';
    let history = [];
    let busy = false;

    function sendNative(action, payload = {}) {
      window.webkit?.messageHandlers?.reactable?.postMessage({ action, payload, t: Date.now() });
    }

    function resizeInput() {
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 160) + 'px';
    }

    function escapeHtml(s) {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // Minimal, self-contained markdown → HTML (no external libs; escapes first).
    function renderMarkdown(src) {
      const blocks = escapeHtml(src).split(/```/);
      let out = '';
      blocks.forEach((chunk, i) => {
        if (i % 2 === 1) { // fenced code block
          const body = chunk.replace(/^[a-zA-Z0-9]*\n/, '');
          out += '<pre><code>' + body.replace(/\n$/, '') + '</code></pre>';
          return;
        }
        const lines = chunk.split('\n');
        let inList = false;
        for (let line of lines) {
          let m;
          if ((m = line.match(/^(#{1,4})\s+(.*)$/))) {
            if (inList) { out += '</ul>'; inList = false; }
            const lvl = m[1].length;
            out += '<h' + lvl + '>' + inline(m[2]) + '</h' + lvl + '>';
          } else if ((m = line.match(/^\s*(?:[-*]|\d+\.)\s+(.*)$/))) {
            if (!inList) { out += '<ul>'; inList = true; }
            out += '<li>' + inline(m[1]) + '</li>';
          } else if (line.trim() === '') {
            if (inList) { out += '</ul>'; inList = false; }
          } else {
            if (inList) { out += '</ul>'; inList = false; }
            out += '<p>' + inline(line) + '</p>';
          }
        }
        if (inList) out += '</ul>';
      });
      return out;
    }

    function inline(s) {
      return s
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/(^|[^*])\*([^*]+)\*/g, '$1<em>$2</em>')
        .replace(/\[([^\]]+)\]\((https?:[^)]+)\)/g, '<a href="$1" target="_blank">$1</a>');
    }

    function append(role, text, extra) {
      const el = document.createElement('div');
      el.className = 'msg ' + role;
      // Assistant replies render markdown; user/system stay literal.
      if (role === 'assistant') el.innerHTML = renderMarkdown(text);
      else el.textContent = text;
      if (extra) {
        const t = document.createElement('div');
        t.className = 'tools';
        t.textContent = extra;
        el.appendChild(t);
      }
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
    }

    function showBanner(html) {
      const el = document.createElement('div');
      el.className = 'banner';
      el.innerHTML = html;
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
    }

    function shortEngine(engine, model) {
      const id = model || engine || '';
      return id.split('/').slice(-1)[0] || 'mlx-lm';
    }

    const modelsEl = document.getElementById('models');
    const composerWrap = document.querySelector('.composer-wrap');
    let pollTimer = null;

    function showModels(on) {
      modelsEl.classList.toggle('show', on);
      log.style.display = on ? 'none' : '';
      composerWrap.style.display = on ? 'none' : '';
    }

    async function loadModels() {
      const res = await fetch('/reactable/agent/models');
      const data = await res.json();
      renderModels(data);
      return data;
    }

    function bytesGB(g) { return g + ' GB'; }

    function renderModels(data) {
      const hw = data.hardware || {};
      let html = '<div class="models-intro">Pick a model to run locally. '
        + '<span class="hw">' + (hw.chip || 'this Mac') + ' · ' + (hw.ram_gb || '?') + ' GB RAM</span></div>';
      (data.tiers || []).forEach(t => {
        const pills = [];
        if (t.recommended) pills.push('<span class="tier-pill">Recommended</span>');
        if (!t.fits) pills.push('<span class="tier-pill warn">Needs ' + t.min_ram_gb + ' GB</span>');
        if (t.cached) pills.push('<span class="tier-pill ok">Downloaded</span>');
        let actions = '';
        if (t.cached) {
          actions = (t.current ? '<button class="btn btn-ghost" disabled>In use</button>'
                                : '<button class="btn btn-primary" data-use="' + t.tier + '">Use this</button>')
                  + '<button class="btn btn-ghost" data-rm="' + t.tier + '">Delete</button>';
        } else {
          actions = '<button class="btn btn-primary" data-pull="' + t.tier + '">Download ' + t.size_gb + ' GB</button>';
        }
        html += '<div class="tier' + (t.recommended ? ' rec' : '') + '" id="tier-' + t.tier + '">'
          + '<div class="tier-top"><span class="tier-name">' + t.tier + '</span>'
          + '<span class="tier-label">' + t.label + '</span>' + pills.join('') + '</div>'
          + '<div class="tier-blurb">' + t.blurb + '</div>'
          + '<div class="tier-meta">' + t.repo + ' · ' + bytesGB(t.size_gb) + ' · needs ' + t.min_ram_gb + ' GB</div>'
          + '<div class="tier-actions">' + actions + '</div></div>';
      });
      modelsEl.innerHTML = html;
      modelsEl.querySelectorAll('[data-pull]').forEach(b => b.onclick = () => pullTier(b.dataset.pull));
      modelsEl.querySelectorAll('[data-rm]').forEach(b => b.onclick = () => rmTier(b.dataset.rm));
      modelsEl.querySelectorAll('[data-use]').forEach(b => b.onclick = () => useTier(b.dataset.use));
    }

    async function pullTier(tier) {
      const card = document.getElementById('tier-' + tier);
      const actions = card.querySelector('.tier-actions');
      actions.innerHTML = '<button class="btn btn-ghost" disabled>Downloading… (a few min)</button>';
      await fetch('/reactable/agent/pull', {
        method: 'POST', headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ tier }),
      });
      // Poll until the tier reports cached.
      const iv = setInterval(async () => {
        const data = await loadModels();
        const t = (data.tiers || []).find(x => x.tier === tier);
        if (t && t.cached) { clearInterval(iv); await useTier(tier); }
      }, 4000);
    }

    async function rmTier(tier) {
      await fetch('/reactable/agent/rm', {
        method: 'POST', headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ tier }),
      });
      loadModels();
    }

    async function useTier(tier) {
      // Downloading sets the tier server-side; just refresh + close if a model exists.
      const data = await loadModels();
      if (data.any_model) { showModels(false); checkStatus(); }
    }

    async function checkStatus() {
      try {
        const res = await fetch('/reactable/agent/status');
        const data = await res.json();
        engineEl.textContent = shortEngine(data.engine, data.model);
        // Gate: no model downloaded → force the picker, hide the chat.
        if (!data.any_model) {
          statusEl.textContent = 'Choose a model to get started';
          statusEl.className = 'header-meta warn';
          showModels(true);
          loadModels();
          return;
        }
        if (data.ok) {
          statusEl.textContent = data.state === 'server-ready'
            ? 'Model ready · offline'
            : 'Model cached · loads on first message';
          statusEl.className = 'header-meta ok';
        } else if (data.state === 'uv-missing') {
          statusEl.textContent = 'uv runtime missing';
          statusEl.className = 'header-meta warn';
          showBanner(
            'The <code>uv</code> Python runner is required to run the local model.<code>curl -LsSf https://astral.sh/uv/install.sh | sh</code>'
          );
        } else {
          statusEl.textContent = data.hint || 'Model not ready';
          statusEl.className = 'header-meta warn';
        }
      } catch (e) {
        statusEl.textContent = 'Nexus unreachable';
        statusEl.className = 'header-meta warn';
        showBanner(String(e));
      }
    }

    function showTyping() {
      const el = document.createElement('div');
      el.className = 'msg assistant typing';
      el.textContent = 'Thinking…';
      el.dataset.typing = '1';
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
      return el;
    }

    async function chat(message) {
      busy = true;
      document.getElementById('tail').classList.add('on');
      sendBtn.disabled = true;
      append('user', message);
      history.push({ role: 'user', content: message });
      const typing = showTyping();
      try {
        const fm = toolFrontmatter();
        const wire = fm ? fm + '\n\n' + message : message;
        const res = await fetch('/reactable/agent/chat', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ message: wire, history: history.slice(0, -1), deck, max_turns: 6 }),
        });
        const data = await res.json();
        typing.remove();
        if (!data.ok) {
          append('error', data.error || 'Chat failed');
          return;
        }
        const meta = [];
        if (data.tools?.length) meta.push(`${data.tools.length} tool run(s)`);
        if (data.turns > 1) meta.push(`${data.turns} turns`);
        if (data.note) meta.push(data.note);
        append('assistant', data.reply || '(empty)', meta.join(' · '));
        history.push({ role: 'assistant', content: data.reply || '' });
      } catch (e) {
        typing.remove();
        append('error', String(e));
      } finally {
        busy = false;
        document.getElementById('tail').classList.remove('on');
        sendBtn.disabled = false;
        input.focus();
      }
    }

    sendBtn.addEventListener('click', () => {
      const text = input.value.trim();
      if (!text || busy) return;
      input.value = '';
      resizeInput();
      chat(text);
    });

    input.addEventListener('input', resizeInput);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendBtn.click();
      }
    });


    // ——— hamburger menu: account links + agent tools ———
    const menuEl = document.getElementById('menu');
    document.getElementById('menu-btn').addEventListener('click', () => {
      menuEl.hidden = !menuEl.hidden;
      if (!menuEl.hidden) renderTools();
    });
    document.addEventListener('pointerdown', (e) => {
      if (!menuEl.hidden && !menuEl.contains(e.target) && !e.target.closest('#menu-btn')) {
        menuEl.hidden = true;
      }
    });
    document.getElementById('connect-youtube').addEventListener('click', (e) => {
      e.preventDefault();
      append('system', 'Run in a terminal: reactable youtube connect');
      menuEl.hidden = true;
    });

    // Agent tools — toggle on/off, optional prompt rides the skill frontmatter.
    const TOOLS = [
      { id: 'voice-enhance', name: 'Voice enhancing', desc: 'DeepFilterNet denoise (edit clean-voice)',
        icon: '<svg viewBox="0 0 24 24"><path d="M12 19v3"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><rect x="9" y="2" width="6" height="13" rx="3"/></svg>' },
      { id: 'silence-detect', name: 'Silence detection', desc: 'trim dead air (edit trim-silence)',
        icon: '<svg viewBox="0 0 24 24"><path d="M2 12h4l3-8 4 16 3-8h6"/></svg>' },
      { id: 'transcribe', name: 'Transcription', desc: 'word-level transcript (takes transcribe)',
        icon: '<svg viewBox="0 0 24 24"><path d="M4 6h16M4 12h10M4 18h7"/></svg>' },
      { id: 'captions', name: 'Captions', desc: 'stage-aligned WEBVTT (edit captions)',
        icon: '<svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 14h4m2 0h6M6 10h2m2 0h8"/></svg>' },
      { id: 'remove-filler', name: 'Filler removal', desc: 'cut ums and stalls (edit remove-filler)',
        icon: '<svg viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg>' },
    ];
    const toolCfg = JSON.parse(localStorage.getItem('agent-tools') || '{}');
    function saveTools() { localStorage.setItem('agent-tools', JSON.stringify(toolCfg)); }

    function renderTools() {
      const box = document.getElementById('tool-list');
      box.innerHTML = '';
      for (const t of TOOLS) {
        const cfg = toolCfg[t.id] || { on: true, prompt: '' };
        toolCfg[t.id] = cfg;
        const row = document.createElement('div');
        row.className = 'tool-row';
        row.innerHTML = `${t.icon}<span class="name" title="${t.desc}">${t.name}</span>
          <button class="tool-more" title="Add a prompt for this tool">⋯</button>
          <button class="tool-toggle${cfg.on ? ' on' : ''}"></button>`;
        const prompt = document.createElement('div');
        prompt.className = 'tool-prompt';
        prompt.innerHTML = `<textarea placeholder="Guidance for the agent when using ${t.name.toLowerCase()}…">${cfg.prompt || ''}</textarea>`;
        row.querySelector('.tool-toggle').addEventListener('click', (e) => {
          cfg.on = !cfg.on;
          e.target.classList.toggle('on', cfg.on);
          saveTools();
        });
        row.querySelector('.tool-more').addEventListener('click', () => prompt.classList.toggle('open'));
        prompt.querySelector('textarea').addEventListener('input', (e) => {
          cfg.prompt = e.target.value;
          saveTools();
        });
        box.appendChild(row);
        box.appendChild(prompt);
      }
    }

    // Frontmatter surfaced to the agent with every message.
    function toolFrontmatter() {
      const lines = [];
      for (const t of TOOLS) {
        const cfg = toolCfg[t.id];
        if (!cfg || !cfg.on) continue;
        lines.push(`- ${t.id}: enabled${cfg.prompt ? ` — ${cfg.prompt.replace(/\n/g, ' ')}` : ''} (${t.desc})`);
      }
      if (!lines.length) return '';
      return '---tools\n' + lines.join('\n') + '\n---';
    }

    append('system', 'Plans decks, runs the reactable CLI, edits files in your project sandbox.');
    // Spawn + warm the model as soon as the window opens, so the first
    // message is fast instead of eating the cold-start. Only if a model exists.
    fetch('/reactable/agent/status').then(r => r.json()).then(s => {
      if (s.any_model) fetch('/reactable/agent/prewarm', { method: 'POST' }).catch(() => {});
    }).catch(() => {});
    checkStatus();
    resizeInput();
    input.focus();
  })();
  </script>
end
