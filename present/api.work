# Present API

Serves deck JSON from `decks/<slug>/deck.work` for the reveal.js stage.

server :reactable_api do
  route "GET /reactable/deck", :deck, auth: :public
  route "GET /reactable/health", :health, auth: :public
  route "GET /reactable/takes", :takes_list, auth: :public
  route "GET /reactable/takes/:id", :take_get, auth: :public
  route "GET /reactable/takes/:id/edit", :take_edit_get, auth: :public
  route "POST /reactable/takes/:id/edit", :take_edit_save, auth: :public
  route "POST /reactable/takes/:id/render", :take_render, auth: :public
  route "POST /reactable/takes/:id/pipeline", :take_pipeline, auth: :public
  route "POST /reactable/exec", :exec_scripts, auth: :public
  route "GET /reactable/decks", :decks_list, auth: :public
  route "GET /reactable/labs/:file", :lab_file, auth: :public
  route "GET /reactable/stage", :stage_status, auth: :public
  route "GET /reactable/stage/poll", :stage_poll, auth: :public
  route "POST /reactable/stage", :stage_command, auth: :public
  route "POST /reactable/stage/ack", :stage_ack, auth: :public
  route "POST /reactable/stage/heartbeat", :stage_heartbeat, auth: :public
  route "GET /reactable/har", :har_list, auth: :public
  route "POST /reactable/har/capture", :har_capture, auth: :public
  route "GET /reactable/har/:id", :har_get, auth: :public
  route "POST /reactable/blitz/replay", :blitz_replay, auth: :public
  route "POST /reactable/agent/chat", :agent_chat, auth: :public
  route "GET /reactable/agent/status", :agent_status, auth: :public
  route "POST /reactable/agent/prewarm", :agent_prewarm, auth: :public
  route "POST /reactable/projects/create", :project_create, auth: :public
  route "GET /reactable/projects/list", :projects_list, auth: :public
  route "GET /reactable/project", :project_get, auth: :public
  route "GET /reactable/surfaces", :surfaces_list, auth: :public

  def health(_req), do: %{ok: true, service: "reactable"}

  def decks_list(_req) do
    root = Path.join(wb_data(), "decks")
    slugs =
      if File.dir?(root) do
        root
        |> File.ls!()
        |> Enum.filter(fn name ->
          File.dir?(Path.join(root, name)) and
            File.exists?(Path.join([root, name, "deck.work"]))
        end)
        |> Enum.sort()
      else
        []
      end

    decks =
      Enum.map(slugs, fn slug ->
        path = Path.join([root, slug, "deck.work"])
        %{slug: slug, title: deck_title_from_file(path) || slug}
      end)

    %{ok: true, decks: decks}
  end

  def takes_list(_req) do
    root = Path.join(wb_data(), "takes")
    ids =
      if File.dir?(root) do
        root
        |> File.ls!()
        |> Enum.filter(&String.starts_with?(&1, "take-"))
        |> Enum.sort(:desc)
      else
        []
      end

    takes =
      Enum.map(ids, fn id ->
        manifest = read_manifest(Path.join(root, id))
        Map.merge(%{id: id}, manifest_summary(manifest))
      end)

    %{ok: true, takes: takes}
  end

  def take_get(req) do
    id = safe_take_id(req.params["id"])
    dir = Path.join([wb_data(), "takes", id])

    cond do
      id == "" -> {400, %{ok: false, error: "id required"}}
      not File.dir?(dir) -> {404, %{ok: false, error: "no such take"}}
      true ->
        manifest = read_manifest(dir)
        events = read_events(Path.join(dir, "events.jsonl"))
        tracks = tracks_for(dir, manifest)
        edit = read_edit(dir)

        %{
          ok: true,
          id: id,
          manifest: manifest,
          events: events,
          tracks: tracks,
          edit: edit,
          render: read_render(dir)
        }
    end
  end

  def take_edit_get(req) do
    id = safe_take_id(req.params["id"])
    dir = Path.join([wb_data(), "takes", id])
    cond do
      id == "" -> {400, %{ok: false, error: "id required"}}
      not File.dir?(dir) -> {404, %{ok: false, error: "no such take"}}
      true -> %{ok: true, id: id, edit: read_edit(dir)}
    end
  end

  def take_edit_save(req) do
    id = safe_take_id(req.params["id"])
    dir = Path.join([wb_data(), "takes", id])
    body = body_map(req)
    cond do
      id == "" -> {400, %{ok: false, error: "id required"}}
      not File.dir?(dir) -> {404, %{ok: false, error: "no such take"}}
      true ->
        edit = Map.get(body, "edit", body)
        path = Path.join(dir, "edit.json")
        File.write!(path, Jason.encode!(edit, pretty: true))
        %{ok: true, id: id, edit: edit}
    end
  end

  def take_render(req) do
    id = safe_take_id(req.params["id"])
    dir = Path.join([wb_data(), "takes", id])
    body = body_map(req)

    cond do
      id == "" -> {400, %{ok: false, error: "id required"}}
      not File.dir?(dir) -> {404, %{ok: false, error: "no such take"}}
      true ->
        if body["edit"], do: File.write!(Path.join(dir, "edit.json"), Jason.encode!(body["edit"], pretty: true))
        aspects = body["aspects"] || ["16:9", "9:16", "1:1"]
        case run_composite(dir, aspects) do
          {:ok, manifest} -> Map.put(manifest, :ok, true)
          {:error, msg} -> {500, %{ok: false, error: msg}}
        end
    end
  end

  def take_pipeline(req) do
    id = safe_take_id(req.params["id"])
    body = body_map(req)
    slug = safe(Map.get(body, "slug", "reactable-demo"))
    script = Path.join([wb_data(), "scripts", "to-video.sh"])
    cond do
      id == "" -> {400, %{ok: false, error: "id required"}}
      not File.exists?(script) -> {500, %{ok: false, error: "pipeline script missing"}}
      true ->
        {out, code} = System.cmd("bash", [script, id, slug], cd: wb_data(), stderr_to_stdout: true)
        if code == 0, do: %{ok: true, id: id, slug: slug, log: String.trim(out)}, else: {500, %{ok: false, error: out}}
    end
  end

  def deck(req) do
    slug = safe(req.query["slug"] || "showcase")
    path = Path.join([wb_data(), "decks", slug, "deck.work"])
    cond do
      slug == "" -> {400, %{ok: false, error: "slug required"}}
      not File.exists?(path) -> {404, %{ok: false, error: "no such deck"}}
      true -> parse_deck(path, slug)
    end
  end

  def exec_scripts(req) do
    body = body_map(req)
    slug = safe(body["deck"] || req.query["deck"] || "showcase")
    trigger = to_string(body["on"] || body["trigger"] || "")
    slide = body["slide"]
    script_id = body["id"] || body["script_id"]
    path = Path.join([wb_data(), "decks", slug, "deck.work"])

    cond do
      slug == "" -> {400, %{ok: false, error: "deck required"}}
      trigger == "" -> {400, %{ok: false, error: "on/trigger required"}}
      not File.exists?(path) -> {404, %{ok: false, error: "no such deck"}}
      true ->
        deck = parse_deck(path, slug)
        scripts = Map.get(deck, :scripts) || Map.get(deck, "scripts") || []
        matched =
          Enum.filter(scripts, fn s ->
            on = s["on"] || s[:on]
            id_ok =
              if script_id in [nil, ""] do
                true
              else
                to_string(s["id"] || s[:id] || "") == to_string(script_id)
              end

            id_ok and to_string(on) == trigger and slide_match?(s, slide)
          end)

        results = Enum.map(matched, fn s -> run_deck_script(slug, s) end)
        %{ok: true, deck: slug, trigger: trigger, slide: slide, ran: length(results), results: results}
    end
  end

  def lab_file(req) do
    file = safe_file(req.params["file"])
    slug = safe(req.query["deck"] || "showcase")
    path = Path.join([wb_data(), "decks", slug, "labs", file])

    cond do
      file == "" -> {400, %{ok: false, error: "file required"}}
      not File.regular?(path) -> {404, %{ok: false, error: "not found"}}
      true -> {200, MIME.from_path(path), File.read!(path)}
    end
  end

  def stage_status(_req) do
    %{
      ok: true,
      live: read_stage_live(),
      pending: read_stage_cmd()
    }
  end

  def stage_poll(_req) do
    case read_stage_cmd() do
      nil -> %{ok: true, command: nil}
      cmd -> %{ok: true, command: cmd}
    end
  end

  def stage_command(req) do
    body = body_map(req)
    action = safe(to_string(body["action"] || ""))

    cond do
      action not in ["open", "hide", "load"] ->
        {400, %{ok: false, error: "action must be open, hide, or load"}}

      true ->
        cmd = %{
          "id" => Base.encode16(:crypto.strong_rand_bytes(8), case: :lower),
          "action" => action,
          "deck" => blank_to_nil(body["deck"]),
          "ts" => System.system_time(:second)
        }

        write_stage_cmd(cmd)
        %{ok: true, id: cmd["id"], command: cmd}
    end
  end

  def stage_ack(req) do
    body = body_map(req)
    id = to_string(body["id"] || "")

    if id != "" and stage_cmd_id() == id do
      clear_stage_cmd()
    end

    %{ok: true}
  end

  def stage_heartbeat(req) do
    body = body_map(req)

    write_stage_live(%{
      "deck" => blank_to_nil(body["deck"]),
      "visible" => body["visible"] in [true, "true", 1, "1"],
      "projectId" => blank_to_nil(body["projectId"]),
      "ts" => body["ts"] || System.system_time(:second)
    })

    %{ok: true}
  end

  defp stage_dir, do: Path.join(wb_data(), ".reactable")
  defp stage_cmd_path, do: Path.join(stage_dir(), "stage-cmd.json")
  defp stage_live_path, do: Path.join(stage_dir(), "stage-live.json")

  defp ensure_stage_dir do
    File.mkdir_p!(stage_dir())
  end

  defp read_stage_json(path) do
    if File.exists?(path) do
      case File.read(path) do
        {:ok, body} ->
          case Jason.decode(body) do
            {:ok, m} when is_map(m) -> m
            _ -> nil
          end

        _ ->
          nil
      end
    else
      nil
    end
  end

  defp write_stage_json(path, map) do
    ensure_stage_dir()
    File.write!(path, Jason.encode!(map))
  end

  defp read_stage_cmd, do: read_stage_json(stage_cmd_path())
  defp read_stage_live, do: read_stage_json(stage_live_path())
  defp stage_cmd_id, do: read_stage_cmd() |> cmd_id()

  defp cmd_id(%{"id" => id}), do: to_string(id)
  defp cmd_id(_), do: ""

  defp write_stage_cmd(cmd), do: write_stage_json(stage_cmd_path(), cmd)
  defp write_stage_live(live), do: write_stage_json(stage_live_path(), live)
  defp clear_stage_cmd, do: File.rm(stage_cmd_path())

  defp blank_to_nil(v) when v in [nil, ""], do: nil
  defp blank_to_nil(v), do: to_string(v)

  defp wb_data, do: System.get_env("WB_DATA") || "."

  defp body_map(req) do
    case req.body do
      m when is_map(m) -> m
      _ -> %{}
    end
  end

  defp read_edit(dir) do
    path = Path.join(dir, "edit.json")
    if File.exists?(path) do
      case File.read(path) do
        {:ok, body} ->
          case Jason.decode(body) do
            {:ok, m} -> m
            _ -> %{}
          end
        _ -> %{}
      end
    else
      %{}
    end
  end

  defp read_render(dir) do
    path = Path.join(dir, "out/render.json")
    if File.exists?(path) do
      case File.read(path) do
        {:ok, body} ->
          case Jason.decode(body) do
            {:ok, m} -> m
            _ -> %{}
          end
        _ -> %{}
      end
    else
      %{}
    end
  end

  defp run_composite(dir, aspects) do
    script = Path.join([wb_data(), "scripts", "composite.py"])
    if File.exists?(script) do
      args = [script, dir | Enum.map(aspects, &to_string/1)]
      {out, code} = System.cmd("python3", args, cd: wb_data(), stderr_to_stdout: true)
      if code != 0 do
        {:error, String.trim(out)}
      else
        case Jason.decode(out) do
          {:ok, m} -> {:ok, m}
          _ -> {:ok, %{raw: String.trim(out)}}
        end
      end
    else
      {:error, "composite.py missing"}
    end
  end

  defp safe_take_id(s) when is_binary(s) do
    s |> String.trim() |> String.replace(~r/[^a-z0-9_-]/, "")
  end
  defp safe_take_id(_), do: ""

  defp safe_file(s) when is_binary(s) do
    s |> String.trim() |> Path.basename()
  end
  defp safe_file(_), do: ""

  defp read_manifest(dir) do
    path = Path.join(dir, "manifest.json")
    if File.exists?(path) do
      case File.read(path) do
        {:ok, body} ->
          case Jason.decode(body) do
            {:ok, m} -> m
            _ -> %{}
          end
        _ -> %{}
      end
    else
      %{}
    end
  end

  defp manifest_summary(m) when is_map(m) do
    %{
      deck: Map.get(m, "deck"),
      source_kind: Map.get(m, "source_kind"),
      capture_target_label: Map.get(m, "capture_target_label"),
      recorded_at: Map.get(m, "recorded_at")
    }
  end
  defp manifest_summary(_), do: %{}

  defp read_events(path) do
    if File.exists?(path) do
      path
      |> File.stream!()
      |> Enum.map(fn line ->
        case Jason.decode(String.trim(line)) do
          {:ok, ev} -> ev
          _ -> nil
        end
      end)
      |> Enum.reject(&is_nil/1)
    else
      []
    end
  end

  defp tracks_for(dir, manifest) do
    declared = get_in(manifest, ["tracks"]) || %{}
    base = "/takes/#{Path.basename(dir)}"

    for {key, file} <- declared, into: %{} do
      full = Path.join(dir, file)
      {key, %{file: file, url: base <> "/" <> file, exists: File.regular?(full)}}
    end
  end

  defp parse_deck(path, slug) do
    content = File.read!(path)
    deck_dir = Path.dirname(path)
    title = deck_title(content) || slug

    work = parse_work_deck(content, deck_dir)

    slides =
      case work.slides do
        [] -> json_block(content, "slides") || []
        s -> s
      end

    preload =
      case work.preload do
        [] -> json_block(content, "preload") || []
        p -> p
      end

    scripts =
      case work.scripts do
        [] -> json_block(content, "scripts") || []
        s -> s
      end

    %{ok: true, slug: slug, title: title, slides: slides, preload: preload, scripts: scripts}
  end

  defp parse_work_deck(content, deck_dir) do
    clients = extract_clients(content)
    file_slides = load_slide_files(Path.join(deck_dir, "slides"))
    inline = parse_inline_work(content, clients)

    slides =
      case {file_slides, inline} do
        {fs, []} when fs != [] -> fs
        {_, ins} -> ins
        {fs, ins} -> ins ++ fs
      end

    %{
      slides: slides,
      preload: parse_preload_blocks(content),
      scripts: parse_script_blocks(content)
    }
  end

  defp load_slide_files(dir) do
    if File.dir?(dir) do
      dir
      |> File.ls!()
      |> Enum.filter(&String.ends_with?(&1, ".work"))
      |> Enum.sort()
      |> Enum.flat_map(fn name ->
        path = Path.join(dir, name)
        clients = extract_clients(File.read!(path))
        parse_inline_work(File.read!(path), clients)
      end)
    else
      []
    end
  end

  defp extract_clients(content) do
    Regex.scan(~r/^client\s+:(\S+)\s+do\r?\n([\s\S]*?)^end\s*$/m, content)
    |> Enum.into(%{}, fn [_, name, body] -> {name, String.trim(body)} end)
  end

  defp parse_inline_work(content, clients) do
    Regex.scan(~r/^slide\s+do\r?\n([\s\S]*?)^end/m, content)
    |> Enum.map(fn [full, attrs_text] ->
      attrs = parse_attrs(attrs_text)
      rest = content |> String.split(full, parts: 2) |> Enum.at(1, "")
      body = slide_trailing_body(rest)
      build_slide(attrs, body, clients)
    end)
  end

  defp slide_trailing_body(rest) do
    case Regex.run(~r/^([\s\S]*?)(?=^(?:slide|script|preload|client\s*:)|\z)/m, rest) do
      [_, body] -> String.trim(body)
      _ -> ""
    end
  end

  defp parse_attrs(text) do
    {attrs, actions} =
      text
      |> String.split("\n")
      |> Enum.reduce({%{}, []}, fn line, {acc, acts} ->
        case String.split(line, ":", parts: 2) do
          ["action", v] -> {acc, [String.trim(v) | acts]}
          [k, v] -> {Map.put(acc, String.trim(k), String.trim(v)), acts}
          _ -> {acc, acts}
        end
      end)

    if actions == [], do: attrs, else: Map.put(attrs, "_actions", Enum.reverse(actions))
  end

  defp build_slide(attrs, body, clients) do
    type = Map.get(attrs, "type", "prose")
    id = Map.get(attrs, "id", "slide")

    slide =
      %{
        "id" => id,
        "type" => normalize_type(type),
        "notes" => Map.get(attrs, "notes")
      }
      |> maybe_put("url", Map.get(attrs, "url"))
      |> maybe_put("src", Map.get(attrs, "src"))
      |> maybe_put("title", Map.get(attrs, "title"))
      |> maybe_put("videoId", Map.get(attrs, "videoId"))
      |> maybe_put("layout", slide_layout(attrs, type))
      |> maybe_put("actions", parse_actions_list(Map.get(attrs, "_actions", [])))

    case type do
      "client" ->
        unit = Map.get(attrs, "unit", "")
        html = Map.get(clients, unit, "")

        slide
        |> Map.put("type", "html")
        |> Map.put("body", html)
        |> Map.put("layout", "fill")

      "html" ->
        slide |> Map.put("body", body) |> Map.put("layout", Map.get(attrs, "layout", "fill"))

      t when t in ["prose", "work", "document"] ->
        theme = Map.get(attrs, "theme", "default")

        slide
        |> Map.put("type", "html")
        |> Map.put("body", prose_to_html(body, theme))
        |> Map.put("layout", "prose")
        |> Map.put("theme", theme)

      t when t in ["iframe", "video", "youtube", "dev", "artifact"] ->
        slide

      _ ->
        slide |> Map.put("type", "html") |> Map.put("body", prose_to_html(body, Map.get(attrs, "theme", "default")))
    end
    |> Enum.reject(fn {_k, v} -> is_nil(v) end)
    |> Map.new()
  end

  defp normalize_type("prose"), do: "html"
  defp normalize_type("work"), do: "html"
  defp normalize_type("document"), do: "html"
  defp normalize_type(t), do: t

  defp slide_layout(attrs, type) do
    case Map.get(attrs, "layout") do
      nil ->
        case type do
          t when t in ["iframe", "video", "youtube", "dev", "artifact", "client"] -> "fill"
          t when t in ["prose", "work", "document"] -> "prose"
          "html" -> "fill"
          _ -> "prose"
        end

      layout ->
        layout
    end
  end

  defp maybe_put(map, _k, nil), do: map
  defp maybe_put(map, k, v), do: Map.put(map, k, v)

  defp parse_actions_list(actions) when is_list(actions) do
    actions
    |> Enum.flat_map(fn
      "wait " <> ms ->
        case Integer.parse(ms) do
          {n, _} -> [%{"type" => "wait", "ms" => n}]
          _ -> []
        end

      "play" ->
        [%{"type" => "play"}]

      "fragment " <> step ->
        case Integer.parse(step) do
          {n, _} -> [%{"type" => "fragment", "step" => n}]
          _ -> []
        end

      _ ->
        []
    end)
    |> case do
      [] -> nil
      list -> list
    end
  end

  defp parse_preload_blocks(content) do
    Regex.scan(~r/^preload\s+do\r?\n([\s\S]*?)^end/m, content)
    |> Enum.flat_map(fn [_, body] ->
      body
      |> String.split("\n")
      |> Enum.map(&String.trim/1)
      |> Enum.reject(&(&1 == ""))
      |> Enum.map(fn line ->
        case String.split(line, ":", parts: 2) do
          ["url", u] -> String.trim(u)
          _ -> line
        end
      end)
    end)
  end

  defp parse_script_blocks(content) do
    Regex.scan(~r/^script\s+do\r?\n([\s\S]*?)^end/m, content)
    |> Enum.map(fn [_, attrs_text] ->
      attrs = parse_attrs(attrs_text)

      %{
        "id" => Map.get(attrs, "id"),
        "on" => Map.get(attrs, "on"),
        "slide" => Map.get(attrs, "slide"),
        "run" => Map.get(attrs, "run"),
        "shell" => Map.get(attrs, "shell"),
        "cwd" => Map.get(attrs, "cwd"),
        "url" => Map.get(attrs, "url"),
        "at" => parse_float(Map.get(attrs, "at")),
        "detach" => Map.get(attrs, "detach") in ["true", "yes", "1"]
      }
      |> Enum.reject(fn {_k, v} -> is_nil(v) or v == false end)
      |> Map.new()
    end)
  end

  defp parse_float(nil), do: nil

  defp parse_float(s) when is_binary(s) do
    case Float.parse(s) do
      {f, _} -> f
      _ -> nil
    end
  end

  defp prose_to_html(""), do: wrap_prose_html("<p></p>", "default")

  defp prose_to_html(text, theme \\ "default") do
    text
    |> String.split("\n")
    |> render_prose_lines([])
    |> Enum.reverse()
    |> Enum.join("\n")
    |> wrap_prose_html(theme)
  end

  defp wrap_prose_html(inner, theme \\ "default") do
    class =
      case theme do
        "title" -> "work-prose deck-title"
        "section" -> "work-prose deck-section"
        "closing" -> "work-prose deck-closing"
        _ -> "work-prose deck-body"
      end

    "<div class=\"#{class}\">#{inner}</div>"
  end

  defp render_prose_lines([], acc), do: acc

  defp render_prose_lines([line | rest], acc) do
    line = String.trim(line)

    cond do
      line == "" ->
        render_prose_lines(rest, acc)

      String.starts_with?(line, "### ") ->
        render_prose_lines(rest, ["<h3>#{inline_prose(String.slice(line, 4..-1//1))}</h3>" | acc])

      String.starts_with?(line, "## ") ->
        render_prose_lines(rest, ["<h2 class=\"deck-h2\">#{inline_prose(String.slice(line, 3..-1//1))}</h2>" | acc])

      String.starts_with?(line, "# ") ->
        render_prose_lines(rest, ["<h1 class=\"deck-h1\">#{inline_prose(String.slice(line, 2..-1//1))}</h1>" | acc])

      String.starts_with?(line, "- ") ->
        {items, rest2} = collect_list(rest, [String.slice(line, 2..-1//1)])
        ul = "<ul class=\"deck-list\">" <> Enum.map_join(items, "", fn i -> "<li>#{inline_prose(i)}</li>" end) <> "</ul>"
        render_prose_lines(rest2, [ul | acc])

      Regex.match?(~r/^\d+\.\s/, line) ->
        {items, rest2} = collect_olist(rest, [Regex.replace(~r/^\d+\.\s/, line, "")])
        ol = "<ol class=\"deck-list\">" <> Enum.map_join(items, "", fn i -> "<li>#{inline_prose(i)}</li>" end) <> "</ol>"
        render_prose_lines(rest2, [ol | acc])

      true ->
        render_prose_lines(rest, ["<p>#{inline_prose(line)}</p>" | acc])
    end
  end

  defp collect_list(lines, acc) do
    case lines do
      [h | t] ->
        h = String.trim(h)

        if String.starts_with?(h, "- ") do
          collect_list(t, [String.slice(h, 2..-1//1) | acc])
        else
          {Enum.reverse(acc), lines}
        end

      _ ->
        {Enum.reverse(acc), []}
    end
  end

  defp collect_olist(lines, acc) do
    case lines do
      [h | t] ->
        h = String.trim(h)

        if Regex.match?(~r/^\d+\.\s/, h) do
          collect_olist(t, [Regex.replace(~r/^\d+\.\s/, h, "") | acc])
        else
          {Enum.reverse(acc), lines}
        end

      _ ->
        {Enum.reverse(acc), []}
    end
  end

  defp inline_prose(text) do
    text
    |> escape_html()
    |> String.replace(~r/\*\*(.+?)\*\*/, "<strong>\\1</strong>")
    |> String.replace(~r/`([^`]+)`/, "<code class=\"deck-code\">\\1</code>")
  end

  defp escape_html(text) do
    text
    |> String.replace("&", "&amp;")
    |> String.replace("<", "&lt;")
    |> String.replace(">", "&gt;")
  end

  defp slide_match?(script, slide) do
    want = script["slide"] || script[:slide]
    if want in [nil, ""] do
      true
    else
      slide != nil and to_string(want) == to_string(slide)
    end
  end

  defp run_deck_script(slug, script) do
    cmd = script["run"] || script[:run] || script["cmd"] || script[:cmd]
    shell = script["shell"] || script[:shell] || "bash"
    cwd_rel = script["cwd"] || script[:cwd] || "."
    detach = script["detach"] || script[:detach] || false
    id = script["id"] || script[:id]

    deck_root = Path.join([wb_data(), "decks", slug])
    cwd = Path.expand(Path.join(deck_root, to_string(cwd_rel)))

    if not String.starts_with?(cwd, Path.expand(deck_root)) do
      %{id: id, ok: false, error: "cwd escapes deck"}
    else
      env =
        (script["env"] || script[:env] || %{})
        |> Enum.map(fn {k, v} -> {to_string(k), to_string(v)} end)

      run_line = to_string(cmd || "")

      if run_line == "" do
        %{id: id, ok: false, error: "empty run"}
      else
        args = if shell == "bash", do: ["-lc", run_line], else: ["-c", run_line]
        opts = [cd: cwd, env: env, stderr_to_stdout: true]

        if detach do
          Task.start(fn ->
            System.cmd(to_string(shell), args, opts)
          end)

          %{id: id, ok: true, detach: true, cmd: run_line, cwd: cwd}
        else
          {out, code} = System.cmd(to_string(shell), args, opts)
          %{id: id, ok: code == 0, code: code, cmd: run_line, cwd: cwd, log: String.trim(out)}
        end
      end
    end
  end

  defp deck_title(content) do
    case Regex.run(~r/title:\s*(.+)/, content) do
      [_, t] -> String.trim(t)
      _ -> nil
    end
  end

  defp deck_title_from_file(path) do
    if File.exists?(path) do
      deck_title(File.read!(path))
    else
      nil
    end
  end

  defp json_block(content, name) do
    re = ~r/```json\s+#{name}\s*\n([\s\S]*?)```/
    case Regex.run(re, content) do
      [_, body] ->
        case Jason.decode(String.trim(body)) do
          {:ok, v} -> v
          _ -> nil
        end
      _ -> nil
    end
  end

  defp har_root(project) do
    Path.join([wb_data(), ".reactable", "har", safe(project)])
  end

  def har_list(req) do
    project = safe(req.query["project"] || "default")
    index = Path.join(har_root(project), "index.json")

    entries =
      if File.exists?(index) do
        case File.read(index) do
          {:ok, body} ->
            case Jason.decode(body) do
              {:ok, list} when is_list(list) -> list
              _ -> []
            end
          _ -> []
        end
      else
        []
      end

    %{ok: true, project: project, entries: entries}
  end

  def har_capture(req) do
    body = body_map(req)
    url = to_string(body["url"] || req.query["url"] || "")
    project = safe(body["project"] || req.query["project"] || "default")

    cond do
      url == "" -> {400, %{ok: false, error: "url required"}}
      true ->
        script = Path.join([wb_data(), "dist", "reactable-tools"])
        args = ["har-capture", url, "--project", project, "--wb-data", wb_data()]

        {out, code} =
          if File.exists?(script) do
            System.cmd(script, args, cd: wb_data(), stderr_to_stdout: true)
          else
            case System.find_executable("reactable-tools") do
              nil -> {"reactable-tools not found — run: reactable tools build", 127}
              bin -> System.cmd(bin, args, cd: wb_data(), stderr_to_stdout: true)
            end
          end

        if code == 0 do
          case Jason.decode(String.trim(out)) do
            {:ok, m} -> Map.put(m, :ok, true)
            _ -> %{ok: true, log: String.trim(out)}
          end
        else
          {500, %{ok: false, error: String.trim(out)}}
        end
    end
  end

  def har_get(req) do
    id = safe(req.params["id"])
    project = safe(req.query["project"] || "default")
    path = Path.join(har_root(project), "#{id}.json")

    cond do
      id == "" -> {400, %{ok: false, error: "id required"}}
      not File.exists?(path) -> {404, %{ok: false, error: "not found"}}
      true ->
        case File.read(path) do
          {:ok, body} ->
            case Jason.decode(body) do
              {:ok, m} -> Map.put(m, :ok, true)
              _ -> {500, %{ok: false, error: "invalid har json"}}
            end
          _ -> {500, %{ok: false, error: "read failed"}}
        end
    end
  end

  def blitz_replay(req) do
    body = body_map(req)
    ref = safe(to_string(body["ref"] || ""))
    project = safe(body["project"] || "default")

    path = Path.join(har_root(project), "#{ref}.json")
    body_path = Path.join(har_root(project), "#{ref}.body.html")

    cond do
      ref == "" -> {400, %{ok: false, error: "ref required"}}
      not File.exists?(path) -> {404, %{ok: false, error: "har ref not found"}}
      true ->
        har = path |> File.read!() |> Jason.decode!()
        url = Map.get(har, "url", "")

        replay =
          cond do
            File.exists?(body_path) ->
              html = File.read!(body_path)
              case Nexus.Browse.Blitz.render_html(html, url) do
                {:ok, text} -> %{via: :cached_blitz, text: text}
                {:error, e} -> %{via: :cached_html, text: String.slice(html, 0, 8000), blitz_error: inspect(e)}
              end

            url != "" ->
              case Nexus.Browse.read(url, render: true) do
                {:ok, m} -> Map.put(m, :via, Map.get(m, :via, :blitz))
                {:error, e} -> %{via: :error, error: inspect(e)}
              end

            true ->
              %{via: :error, error: "no body or url"}
          end

        %{ok: true, ref: ref, url: url, replay: replay, assets: Map.get(har, "assets", [])}
    end
  end

  def agent_status(_req) do
    bin = tools_bin()
    cond do
      not File.exists?(bin) ->
        %{ok: false, backend: "rust-mlx", error: "reactable-tools missing — run: reactable tools build"}

      true ->
        {out, code} = System.cmd(bin, ["agent-status"], cd: wb_data(), stderr_to_stdout: true)
        case Jason.decode(String.trim(out)) do
          {:ok, m} -> Map.merge(%{ok: code == 0, backend: "nexus+mlx"}, m)
          _ -> %{ok: code == 0, backend: "nexus+mlx", log: String.trim(out)}
        end
    end
  end

  # Fire-and-forget: spawn + warm the model server in the background so the
  # first real turn is hot. Returns immediately; safe to call repeatedly.
  def agent_prewarm(_req) do
    if System.get_env("REACTABLE_AGENT_STUB") == "1" do
      %{ok: true, prewarm: :stub}
    else
      bin = tools_bin()

      if File.exists?(bin) do
        Task.start(fn ->
          System.cmd(bin, ["agent-serve"], cd: wb_data(), stderr_to_stdout: true)
        end)

        %{ok: true, prewarm: :started}
      else
        %{ok: false, error: "reactable-tools not found"}
      end
    end
  end

  def agent_chat(req) do
    body = body_map(req)
    message = to_string(body["message"] || "")
    history = body["history"] || []
    deck = safe(body["deck"] || "showcase")
    max_turns = min(max_turns(body["max_turns"]), 8)

    cond do
      message == "" -> {400, %{ok: false, error: "message required"}}
      true ->
        case agent_turn_loop(message, history, deck, max_turns) do
          {:ok, result} -> Map.put(result, :ok, true)
          {:error, e} -> {500, %{ok: false, error: e}}
        end
    end
  end

  def projects_list(_req) do
    projects = Enum.map(discover_project_roots(), &project_summary/1)
    %{ok: true, projects: projects}
  end

  # Full project aggregate — the three deliverables (research · decks · takes)
  # plus a flat Surface list (the atoms the Stage can show). Defaults to the
  # active project (wb_data) when no id is given.
  def project_get(req) do
    id = safe(req.query["id"] || "")
    root =
      if id == "" do
        wb_data()
      else
        Enum.find(discover_project_roots(), wb_data(), fn p -> Path.basename(p) == id end)
      end

    summary = project_summary(root)

    Map.merge(summary, %{
      ok: true,
      research: research_items(root),
      decks: deck_surfaces(root),
      takes: take_surfaces(root),
      surfaces: surfaces_for(root, summary.id)
    })
  end

  # Flat Surface list. `?project=<id>` scopes to one project; otherwise every
  # discovered project (feeds the cross-project ⌘I palette).
  def surfaces_list(req) do
    project = safe(req.query["project"] || "")

    roots =
      if project == "" do
        discover_project_roots()
      else
        discover_project_roots() |> Enum.filter(fn p -> Path.basename(p) == project end)
      end

    surfaces =
      Enum.flat_map(roots, fn root ->
        surfaces_for(root, Path.basename(root))
      end)

    %{ok: true, surfaces: surfaces}
  end

  defp project_summary(path) do
    %{id: Path.basename(path), name: project_title_at(path) || Path.basename(path), path: path}
  end

  # A Surface is the atom the Stage shows: {kind, id, title, ref, project, kinds}.
  # kind ∈ deck | take | doc | web | hyperframes | youtube | artifact.
  defp surfaces_for(root, project_id) do
    deck_surfaces(root, project_id) ++
      take_surfaces(root, project_id) ++
      doc_surfaces(root, project_id) ++
      research_surfaces(root, project_id)
  end

  defp deck_surfaces(root, project_id \\ nil) do
    pid = project_id || Path.basename(root)
    dir = Path.join(root, "decks")

    if File.dir?(dir) do
      dir
      |> File.ls!()
      |> Enum.filter(fn s -> File.exists?(Path.join([dir, s, "deck.work"])) end)
      |> Enum.sort()
      |> Enum.map(fn slug ->
        title = deck_title_from_file(Path.join([dir, slug, "deck.work"])) || slug
        %{kind: "deck", id: "deck:#{slug}", title: title, ref: slug, project: pid}
      end)
    else
      []
    end
  end

  defp take_surfaces(root, project_id \\ nil) do
    pid = project_id || Path.basename(root)
    dir = Path.join(root, "takes")

    if File.dir?(dir) do
      dir
      |> File.ls!()
      |> Enum.filter(&String.starts_with?(&1, "take-"))
      |> Enum.sort(:desc)
      |> Enum.map(fn id ->
        %{kind: "take", id: "take:#{id}", title: id, ref: id, project: pid}
      end)
    else
      []
    end
  end

  # Markdown / .work docs at the project root become `doc` surfaces.
  defp doc_surfaces(root, project_id) do
    if File.dir?(root) do
      root
      |> File.ls!()
      |> Enum.filter(fn f ->
        (String.ends_with?(f, ".md") or String.ends_with?(f, ".work")) and
          File.regular?(Path.join(root, f))
      end)
      |> Enum.sort()
      |> Enum.map(fn f ->
        %{kind: "doc", id: "doc:#{f}", title: f, ref: f, project: project_id}
      end)
    else
      []
    end
  end

  defp research_items(root) do
    dir = Path.join(root, "research")

    if File.dir?(dir) do
      dir
      |> File.ls!()
      |> Enum.sort()
      |> Enum.map(fn item ->
        %{id: item, path: Path.join(dir, item)}
      end)
    else
      []
    end
  end

  defp research_surfaces(root, project_id) do
    Enum.map(research_items(root), fn item ->
      %{kind: "research", id: "research:#{item.id}", title: item.id, ref: item.id, project: project_id}
    end)
  end

  def project_create(req) do
    body = body_map(req)
    title = String.trim(to_string(body["title"] || "Untitled"))
    slug = safe(body["slug"] || slugify_title(title))

    cond do
      title == "" -> {400, %{ok: false, error: "title required"}}
      slug == "" -> {400, %{ok: false, error: "invalid slug"}}
      true ->
        case scaffold_project(slug, title) do
          {:ok, path} ->
            register_project_path(path)
            %{ok: true, slug: slug, title: title, path: path}

          {:error, e} ->
            {500, %{ok: false, error: e}}
        end
    end
  end

  defp agent_turn_loop(message, history, deck, max_turns) do
    system = agent_system_prompt(deck)
    messages = history ++ [%{"role" => "user", "content" => message}]
    agent_turns(system, messages, max_turns, 0, [])
  end

  # Full transcript (including the original user message) rides through every
  # recursion — assistant turns and tool results are appended, never replaced.
  defp agent_turns(system, messages, max_turns, turn, tool_log) do
    case llm_complete(system, messages) do
      {:ok, text} ->
        case parse_tool_calls(text) do
          [] ->
            if malformed_tool_block?(text) and turn + 1 < max_turns do
              retry =
                "Your tool block was malformed JSON. Emit ONLY one valid tool block: " <>
                  ~s(```tool\n{"name":"...","args":{...}}\n```)

              agent_turns(
                system,
                messages ++
                  [%{"role" => "assistant", "content" => text}, %{"role" => "user", "content" => retry}],
                max_turns,
                turn + 1,
                tool_log
              )
            else
              {:ok, %{reply: text, tools: tool_log, turns: turn + 1}}
            end

          _tools when turn + 1 >= max_turns ->
            {:ok, %{reply: text, tools: tool_log, turns: turn + 1, note: "max turns"}}

          tools ->
            results =
              Enum.map(tools, fn tool ->
                out = run_agent_tool(tool)
                %{tool: tool, result: out}
              end)

            followup =
              "Tool results:\n" <>
                Enum.map_join(results, "\n", fn r ->
                  Jason.encode!(r)
                end)

            agent_turns(
              system,
              messages ++
                [%{"role" => "assistant", "content" => text}, %{"role" => "user", "content" => followup}],
              max_turns,
              turn + 1,
              tool_log ++ results
            )
        end

      {:error, e} ->
        {:error, e}
    end
  end

  defp malformed_tool_block?(text) when is_binary(text) do
    String.contains?(text, "```tool") and parse_tool_calls(text) == []
  end

  # REACTABLE_AGENT_STUB=1 — deterministic LLM stand-in for loop/sandbox tests:
  # a user message containing "STUB:" is echoed back verbatim (everything after
  # the marker), so tests can drive exact tool blocks; anything else → "done".
  defp llm_complete(system, messages) do
    if System.get_env("REACTABLE_AGENT_STUB") == "1" do
      last_user =
        messages
        |> Enum.reverse()
        |> Enum.find_value(fn m ->
          role = m["role"] || m[:role]
          if to_string(role) == "user", do: to_string(m["content"] || m[:content] || "")
        end)

      case last_user && String.split(last_user, "STUB:", parts: 2) do
        [_, payload] -> {:ok, payload}
        _ -> {:ok, "done"}
      end
    else
      llm_complete_server(system, messages)
    end
  end

  defp llm_complete_server(system, messages) do
    bin = tools_bin()

    unless File.exists?(bin) do
      {:error, "reactable-tools not found"}
    else
      req = %{system: system, messages: Enum.map(messages, &normalize_msg/1), max_tokens: 2048}
      tmp_in = Path.join(System.tmp_dir!(), "reactable-agent-in-#{System.unique_integer([:positive])}.json")
      tmp_out = Path.join(System.tmp_dir!(), "reactable-agent-out-#{System.unique_integer([:positive])}.json")
      File.write!(tmp_in, Jason.encode!(req))

      try do
        {_, code} = System.cmd(bin, ["agent-chat", "--input", tmp_in, "--output", tmp_out], cd: wb_data(), stderr_to_stdout: true)

        body =
          if File.exists?(tmp_out) do
            File.read!(tmp_out)
          else
            ""
          end

        case Jason.decode(body) do
          {:ok, %{"ok" => true, "text" => text}} -> {:ok, text}
          {:ok, %{"error" => err}} -> {:error, err}
          _ when code != 0 -> {:error, String.trim(body)}
          _ -> {:error, "agent-chat failed"}
        end
      after
        File.rm(tmp_in)
        File.rm(tmp_out)
      end
    end
  end

  defp normalize_msg(%{"role" => role, "content" => content}), do: %{role: role, content: to_string(content)}
  defp normalize_msg(%{role: role, content: content}), do: %{role: to_string(role), content: to_string(content)}
  defp normalize_msg(other), do: %{role: "user", content: inspect(other)}

  defp parse_tool_calls(text) when is_binary(text) do
    Regex.scan(~r/```tool\s*\n([\s\S]*?)```/m, text)
    |> Enum.map(fn [_, body] -> Jason.decode!(String.trim(body)) end)
    |> Enum.filter(&is_map/1)
  rescue
    _ -> []
  end

  defp run_agent_tool(%{"name" => "bash", "args" => %{"cmd" => cmd}}) when is_binary(cmd) do
    if sandbox_cmd_allowed?(cmd) do
      # Scrubbed environment + non-login shell: no user profile, no inherited env.
      args =
        ["-i" | Enum.map(sandbox_env(), fn {k, v} -> "#{k}=#{v}" end)] ++
          ["/bin/bash", "-c", cmd]

      {out, code} = System.cmd("/usr/bin/env", args, cd: wb_data(), stderr_to_stdout: true)
      %{ok: code == 0, code: code, output: String.slice(out, 0, 8000)}
    else
      %{ok: false, error: "command not allowed in sandbox"}
    end
  end

  defp run_agent_tool(%{"name" => "read_file", "args" => %{"path" => path}}) when is_binary(path) do
    case safe_read(path) do
      {:ok, body} -> %{ok: true, path: path, content: String.slice(body, 0, 12000)}
      {:error, e} -> %{ok: false, error: e}
    end
  end

  defp run_agent_tool(%{"name" => "write_file", "args" => %{"path" => path, "content" => content}}) when is_binary(path) do
    case safe_write(path, to_string(content || "")) do
      :ok -> %{ok: true, path: path}
      {:error, e} -> %{ok: false, error: e}
    end
  end

  defp run_agent_tool(%{"name" => name}) do
    %{ok: false, error: "unknown tool #{name}"}
  end

  defp run_agent_tool(_), do: %{ok: false, error: "invalid tool payload"}

  defp sandbox_cmd_allowed?(cmd) do
    cmd = String.trim(cmd)
    # "bun run " only — bare "bun " would allow `bun x <pkg>` (arbitrary code).
    allowed_prefixes = ["reactable ", "bun run ", "ffmpeg ", "bash scripts/", "python3 scripts/"]
    Enum.any?(allowed_prefixes, &String.starts_with?(cmd, &1))
  end

  defp sandbox_env do
    home = System.get_env("HOME") || "/tmp"
    # Include the user bin dirs where `reactable` (bun link) and uv land, so the
    # allowlisted `reactable …` commands actually resolve. Still no profile sourced.
    path =
      Enum.join(
        [
          "#{home}/.bun/bin",
          "#{home}/.local/bin",
          "/opt/homebrew/bin",
          "/usr/local/bin",
          "/usr/bin",
          "/bin"
        ],
        ":"
      )

    [
      {"WB_DATA", wb_data()},
      {"HOME", home},
      {"PATH", path}
    ]
  end

  defp safe_read(rel) do
    path = safe_path(rel)
    if path && File.exists?(path), do: {:ok, File.read!(path)}, else: {:error, "missing or outside sandbox"}
  end

  defp safe_write(rel, content) do
    path = safe_path(rel)
    if path do
      File.mkdir_p!(Path.dirname(path))
      File.write!(path, content)
      :ok
    else
      {:error, "path outside sandbox"}
    end
  end

  defp safe_path(rel) when is_binary(rel) do
    root = realpath(Path.expand(wb_data()))
    path = realpath(Path.expand(Path.join(root, rel)))
    if String.starts_with?(path, root <> "/") or path == root, do: path, else: nil
  end

  defp safe_path(_), do: nil

  # Resolve symlinks at every component so a link inside the sandbox can't
  # point reads/writes outside it. Works for not-yet-existing leaves.
  defp realpath(path, depth \\ 0)
  defp realpath(path, depth) when depth > 40, do: path

  defp realpath(path, depth) do
    case :file.read_link(path) do
      {:ok, target} ->
        realpath(Path.expand(to_string(target), Path.dirname(path)), depth + 1)

      _ ->
        dir = Path.dirname(path)
        if dir == path, do: path, else: Path.join(realpath(dir, depth + 1), Path.basename(path))
    end
  end

  defp tools_bin do
    bundled = Path.join([wb_data(), "dist", "reactable-tools"])
    if File.exists?(bundled), do: bundled, else: System.find_executable("reactable-tools") || bundled
  end

  defp agent_system_prompt(deck) do
    prompt_path = Path.join([wb_data(), "skill", "dist", "agent-prompt.txt"])

    base =
      if File.exists?(prompt_path) do
        File.read!(prompt_path)
      else
        "You are the Reactable local agent. Help author decks, run reactable CLI, and plan videos."
      end

    base <>
      """

      ## Local agent tools (offline)

      To act inside the project sandbox (`#{wb_data()}`), emit ONE tool block and nothing else — no prose before or after it:

      ```tool
      {"name":"bash","args":{"cmd":"reactable decks list"}}
      ```

      Allowed tools:
      - `bash` — commands starting with: reactable, bun run, ffmpeg, bash scripts/, python3 scripts/
      - `read_file` — args: {"path": "relative/path"}
      - `write_file` — args: {"path": "relative/path", "content": "..."}

      Example — read a deck, then answer:
      user: What is the first slide?
      assistant: ```tool
      {"name":"read_file","args":{"path":"decks/demo/deck.work"}}
      ```
      user: Tool results: {...}
      assistant: The first slide is "welcome".

      When no tool is needed, answer directly. After tool results arrive, either emit another tool block or give the final answer.

      Active deck: #{deck}
      """
  end

  defp discover_project_roots do
    user_root = Path.expand("~/Reactable")
    manifest = Path.join(user_root, "projects.json")
    paths = [wb_data()]

    paths =
      if File.exists?(manifest) do
        case Jason.decode(File.read!(manifest)) do
          {:ok, %{"paths" => list}} when is_list(list) -> paths ++ list
          _ -> paths
        end
      else
        paths
      end

    user_projects = Path.join(user_root, "projects")
    paths =
      if File.dir?(user_projects) do
        paths ++
          (File.ls!(user_projects)
           |> Enum.map(&Path.join(user_projects, &1)))
      else
        paths
      end

    paths
    |> Enum.map(fn p -> Path.expand(p) end)
    |> Enum.filter(fn p -> File.exists?(Path.join(p, "index.work")) end)
    # Dedup on the symlink-resolved, case-folded real path so the manifest entry,
    # wb_data, and the ~/Reactable/projects/<x> convenience symlink (which points
    # back at the same dir) collapse to one project.
    |> Enum.uniq_by(fn p -> String.downcase(realpath(p)) end)
  end

  defp project_title_at(root) do
    path = Path.join(root, "index.work")
    if File.exists?(path) do
      path
      |> File.read!()
      |> String.split("\n", parts: 20)
      |> Enum.find_value(fn line ->
        if String.starts_with?(line, "# "), do: String.trim(String.slice(line, 2..-1//1))
      end)
    end
  end

  defp scaffold_project(slug, title) do
    root = Path.expand(Path.join("~/Reactable/projects", slug))
    if File.exists?(root), do: {:error, "project exists: #{slug}"}

    File.mkdir_p!(root)
    File.mkdir_p!(Path.join(root, "decks"))
    File.mkdir_p!(Path.join(root, "takes"))

    index = """
    # #{title}

    Reactable project — created by local agent.
    """

    deck = """
    id: #{slug}
    title: #{title}

    slide do
      id: welcome
      type: prose
      body: |
        # #{title}

        Built with the Reactable local agent.
    end
    """

    File.write!(Path.join(root, "index.work"), index)
    deck_dir = Path.join([root, "decks", slug])
    File.mkdir_p!(deck_dir)
    File.write!(Path.join(deck_dir, "deck.work"), deck)
    {:ok, root}
  end

  defp register_project_path(path) do
    user_root = Path.expand("~/Reactable")
    File.mkdir_p!(user_root)
    manifest = Path.join(user_root, "projects.json")

    data =
      if File.exists?(manifest) do
        case Jason.decode(File.read!(manifest)) do
          {:ok, m} when is_map(m) -> m
          _ -> %{"version" => 1, "paths" => []}
        end
      else
        %{"version" => 1, "paths" => []}
      end

    paths = Map.get(data, "paths", [])
    unless path in paths do
      data = Map.put(data, "paths", paths ++ [path])
      File.write!(manifest, Jason.encode!(data, pretty: true))
    end

    :ok
  end

  defp slugify_title(title) do
    title
    |> String.downcase()
    |> String.replace(~r/[^a-z0-9]+/, "-")
    |> String.trim("-")
  end

  defp max_turns(v) when is_integer(v), do: v
  defp max_turns(v) when is_binary(v) do
    case Integer.parse(v) do
      {n, _} -> n
      _ -> 6
    end
  end
  defp max_turns(_), do: 6

  defp safe(s) when is_binary(s) do
    s |> String.trim() |> String.replace(~r/[^a-z0-9_-]/, "")
  end
  defp safe(_), do: ""
end

# YouTube — same OAuth stack as studio (~/.shinyobjectz/youtube_client.json + tools/youtube_auth.py)
server :reactable_youtube_api do
  route "GET /reactable/youtube/status", :yt_status, auth: :public
  route "POST /reactable/youtube/connect", :yt_connect, auth: :public
  route "POST /reactable/youtube/disconnect", :yt_disconnect, auth: :public
  route "GET /reactable/youtube/search", :yt_search, auth: :public
  route "GET /reactable/youtube/proxy", :yt_proxy, auth: :public

  def yt_disconnect(_req) do
    t = yt_token()
    if File.exists?(t), do: File.rm!(t)
    %{ok: true, connected: false}
  end

  defp yt_token, do: Path.expand("~/.shinyobjectz/youtube_token.json")
  defp yt_client, do: System.get_env("YOUTUBE_CLIENT_SECRETS") || Path.expand("~/.shinyobjectz/youtube_client.json")
  defp yt_result, do: Path.expand("~/.shinyobjectz/youtube_auth_result.json")
  defp yt_url, do: Path.expand("~/.shinyobjectz/youtube_auth_url.txt")

  defp tools_root do
    System.get_env("SHINYOBJECTZ_ROOT") || Path.expand("../../", wb_data())
  end

  defp wait_for_url(ms) when ms <= 0, do: nil
  defp wait_for_url(ms) do
    case File.read(yt_url()) do
      {:ok, u} when byte_size(u) > 0 -> String.trim(u)
      _ -> Process.sleep(100); wait_for_url(ms - 100)
    end
  end

  defp py(script, args) do
    {out, code} =
      System.cmd("python3", [Path.join(tools_root(), "tools/#{script}") | args],
        env: [{"PYTHONWARNINGS", "ignore"}],
        stderr_to_stdout: true
      )

    case last_json(out) do
      {:ok, m} -> m
      :error -> %{"ok" => false, "error" => "exit #{code}: #{String.slice(String.trim(out), 0, 400)}"}
    end
  rescue
    e -> %{"ok" => false, "error" => Exception.message(e)}
  end

  defp last_json(out) do
    out
    |> String.split("\n", trim: true)
    |> Enum.reverse()
    |> Enum.find_value(:error, fn line ->
      case Jason.decode(line) do
        {:ok, m} when is_map(m) -> {:ok, m}
        _ -> nil
      end
    end)
  end

  def yt_status(_req) do
    connected = File.exists?(yt_token())
    %{ok: true, connected: connected, client: File.exists?(yt_client()), error: (if connected, do: nil, else: yt_last_error())}
  end

  defp yt_last_error do
    with {:ok, j} <- File.read(yt_result()),
         {:ok, %{"ok" => false, "error" => e}} <- Jason.decode(j) do
      e
    else
      _ -> nil
    end
  end

  def yt_connect(_req) do
    cond do
      not File.exists?(yt_client()) ->
        {400, %{ok: false, error: "no OAuth client — add ~/.shinyobjectz/youtube_client.json (same as studio)"}}

      File.exists?(yt_token()) ->
        %{ok: true, connected: true}

      true ->
        File.rm(yt_result())
        File.rm(yt_url())
        spawn(fn ->
          res = py("youtube_auth.py", [])
          File.write(yt_result(), Jason.encode!(res))
        end)
        %{ok: true, started: true, url: wait_for_url(2500)}
    end
  end

  def yt_search(req) do
    q = safe(String.trim(req.query["q"] || ""))
    if q == "", do: {400, %{ok: false, error: "q required"}}, else: py("youtube_search.py", [q])
  end

  def yt_proxy(req) do
    vid = safe(String.trim(req.query["v"] || ""))
    start = String.replace(String.trim(req.query["start"] || "0"), ~r/[^0-9]/, "")

    if vid == "" do
      {400, %{ok: false, error: "v required"}}
    else
      origin = "http://127.0.0.1:#{System.get_env("PORT") || "4020"}"
      embed = "https://www.youtube.com/embed/#{vid}?start=#{start}&rel=0&modestbranding=1&playsinline=1&origin=#{URI.encode(origin)}"

      %{
        ok: true,
        videoId: vid,
        embed: embed,
        proxyUrl: "/reactable/youtube/proxy?v=#{vid}&start=#{start}"
      }
    end
  end

  defp wb_data, do: System.get_env("WB_DATA") || "."

  defp safe(s) when is_binary(s) do
    s |> String.trim() |> String.replace(~r/[^a-z0-9_-]/, "")
  end

  defp safe(_), do: ""
end
