{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emily2040.github.io/nano-banana-image-skill/schemas/pack-format.json",
  "title": "Nano Banana Skill Pack Format",
  "description": "Manifest schema for shipping the skill as a GitHub-ready portable pack.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "entrypoints",
    "targets",
    "directories"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skill",
        "agents",
        "claude",
        "gemini",
        "readme"
      ],
      "properties": {
        "skill": {
          "type": "string"
        },
        "agents": {
          "type": "string"
        },
        "claude": {
          "type": "string"
        },
        "gemini": {
          "type": "string"
        },
        "readme": {
          "type": "string"
        },
        "site": {
          "type": "string"
        },
        "openai": {
          "type": "string"
        }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "models",
        "agents"
      ],
      "properties": {
        "models": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "directories": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemas",
        "registry",
        "skills",
        "examples",
        "scripts",
        "docs"
      ],
      "properties": {
        "schemas": {
          "type": "string"
        },
        "registry": {
          "type": "string"
        },
        "skills": {
          "type": "string"
        },
        "examples": {
          "type": "string"
        },
        "scripts": {
          "type": "string"
        },
        "docs": {
          "type": "string"
        },
        "agents": {
          "type": "string"
        },
        "workflows": {
          "type": "string"
        }
      }
    },
    "quality_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "examples": [
    {
      "name": "nano-banana-image-skill",
      "version": "1.0.0",
      "description": "Portable skill pack for Gemini image prompting and editing.",
      "entrypoints": {
        "skill": "SKILL.md",
        "agents": "AGENTS.md",
        "claude": "CLAUDE.md",
        "gemini": "GEMINI.md",
        "readme": "README.md",
        "site": "docs/index.html",
        "openai": "agents/openai.yaml"
      },
      "targets": {
        "models": [
          "gemini-3-pro-image-preview",
          "gemini-3.1-flash-image-preview",
          "gemini-2.5-flash-image"
        ],
        "agents": [
          "codex",
          "claude-code",
          "gemini-cli",
          "antigravity",
          "other-agents-md-clients"
        ]
      },
      "directories": {
        "schemas": "schemas",
        "registry": "registry",
        "skills": "skills",
        "examples": "examples",
        "scripts": "scripts",
        "docs": "docs",
        "agents": "agents",
        "workflows": ".github/workflows"
      },
      "quality_gates": [
        "jsonschema validation",
        "example validation",
        "runtime parity validation",
        "Gemini request adapter validation",
        "documentation asset validation",
        "static docs",
        "cross-agent entrypoints"
      ]
    }
  ]
}
